# Copy to .env and adjust. Service names (postgres/elasticsearch/redis) = docker-compose hostnames.

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=knowledge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/knowledge

ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:8080

# Auth — generate a strong random JWT_SECRET for any real deployment.
JWT_SECRET=change-me-in-prod
JWT_EXPIRE_MINUTES=1440
# Demo account seeded at startup (empty DEMO_USER disables seeding).
DEMO_USER=demo
DEMO_PASSWORD=demo12345

# Frontend (Vite) — baked at build time.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Monitoring — replace the password before exposing Grafana anywhere non-local.
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme
